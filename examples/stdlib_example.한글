# 표준 라이브러리 예제

# 수학 함수
보여줘("제곱근(16):")
보여줘(제곱근(16))

보여줘("절댓값(-5):")
보여줘(절댓값(-5))

보여줘("거듭제곱(2, 10):")
보여줘(거듭제곱(2, 10))

보여줘("최댓값(3, 7, 2, 9, 1):")
보여줘(최댓값(3, 7, 2, 9, 1))

# 문자열 함수
변수 문자열 = "안녕하세요"
보여줘("문자열 길이:")
보여줘(길이(문자열))

변수 영어 = "Hello World"
보여줘("대문자:")
보여줘(대문자(영어))

# 랜덤 함수
보여줘("1부터 100까지 정수난수:")
보여줘(정수난수(1, 100))

변수 선택지 = ["가위", "바위", "보"]
보여줘("랜덤 선택:")
보여줘(선택(선택지))

# 리스트 함수
변수 목록 = [5, 2, 8, 1, 9]
보여줘("정렬 전:")
보여줘(목록)
보여줘("정렬 후:")
보여줘(정렬(목록))

# 숫자가 포함된 변수명 테스트

변수 변수1 = 10
변수 변수2 = 20
변수 숫자3 = 30

보여줘("변수1 = ")
보여줘(변수1)

보여줘("변수2 = ")
보여줘(변수2)

보여줘("숫자3 = ")
보여줘(숫자3)

# 계산
변수 합계 = 변수1 + 변수2 + 숫자3
보여줘("합계 = ")
보여줘(합계)

# 영문 + 숫자
변수 test1 = 100
변수 value2 = 200
변수 result3 = test1 + value2

보여줘("result3 = ")
보여줘(result3)
